{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmm.kalshi.raw_capture_record.v2",
  "type": "object",
  "required": ["schema", "kind", "raw_ingress_ordinal", "received_at_utc_ns"],
  "properties": {
    "schema": {"const": "pmm.kalshi.raw_capture_record.v2"},
    "kind": {"enum": ["connection_attempt", "connection_opened", "subscription_sent", "inbound_frame", "subscription_acknowledged", "connection_gap", "connection_closed", "binary_frame_rejected"]},
    "raw_ingress_ordinal": {"type": "integer", "minimum": 1},
    "received_at_utc_ns": {"type": "integer", "minimum": 0},
    "connection_segment_id": {"type": "integer", "minimum": 1},
    "websocket_url": {"type": "string"},
    "subscription_request_id": {"type": "string"},
    "wire_request_id": {"type": "integer"},
    "subscription": {"type": "object"},
    "message_type": {"type": "string"},
    "subscription_id": {},
    "source_sequence": {},
    "market_ticker": {"type": ["string", "null"]},
    "venue_market_id": {"type": ["string", "null"]},
    "raw_frame_utf8": {"type": "string"},
    "channel": {"type": "string"},
    "venue_subscription_id": {"type": "string"},
    "requested_market_tickers": {"type": "array", "items": {"type": "string"}},
    "membership_claim": {"type": "string"},
    "failure_phase": {"type": "string"},
    "error_type": {"type": "string"},
    "error_code": {"type": "string"},
    "reconnect_delay_seconds": {"type": "integer", "minimum": 0},
    "close_reason": {"type": "string"},
    "clean": {"type": "boolean"},
    "byte_length": {"type": "integer", "minimum": 0}
  },
  "additionalProperties": false
}
