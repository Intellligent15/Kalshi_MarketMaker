{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "stage", "command_sha256", "started_at_utc", "finished_at_utc", "wall_time_seconds", "child", "termination", "teardown", "sampling", "streams", "storage", "machine", "identity_files"],
  "properties": {
    "schema": {"const": "pmm.phase7.b2c_measurement.v2"}, "stage": {"type": "string", "minLength": 1},
    "command_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "started_at_utc": {"type": "string", "format": "date-time"}, "finished_at_utc": {"type": "string", "format": "date-time"}, "wall_time_seconds": {"type": "number", "minimum": 0},
    "child": {"type": "object", "additionalProperties": false, "required": ["exit_code"], "properties": {"exit_code": {"type": ["integer", "null"]}}},
    "termination": {"type": "object", "additionalProperties": false, "required": ["reason", "stop_initiator", "signals", "grace_expiries", "escalation_cause"], "properties": {"reason": {"enum": ["completed", "child_failure", "operator_interrupted", "raw_budget_exceeded", "aggregate_budget_exceeded", "stream_budget_exceeded", "sampler_failure", "wrapper_failure", "teardown_failure"]}, "stop_initiator": {"enum": ["child", "operator", "policy", "sampler", "wrapper", "teardown"]}, "signals": {"type": "array", "items": {"type": "string"}}, "grace_expiries": {"type": "array", "uniqueItems": true, "items": {"enum": ["sigint", "sigterm", "quiescence"]}}, "escalation_cause": {"type": ["string", "null"], "enum": [null, "second_interrupt", "sigint_grace_expired", "sigterm_grace_expired", "quiescence_grace_expired"]}}},
    "teardown": {"type": "object", "additionalProperties": false, "required": ["direct_child_reaped", "process_group_quiescent", "zombie_members_observed", "group_absence_confirmed", "output_finalization"], "properties": {"direct_child_reaped": {"type": "boolean"}, "process_group_quiescent": {"type": "boolean"}, "zombie_members_observed": {"type": "integer", "minimum": 0}, "group_absence_confirmed": {"type": "boolean"}, "output_finalization": {"enum": ["cooperative", "forced", "unknown"]}}},
    "sampling": {"type": "object", "additionalProperties": false, "required": ["valid", "sampler_identity", "attempted_samples", "successful_samples", "error_code", "peak_process_count", "peak_rss_kib"], "properties": {"valid": {"type": "boolean"}, "sampler_identity": {"type": "string"}, "attempted_samples": {"type": "integer", "minimum": 0}, "successful_samples": {"type": "integer", "minimum": 0}, "error_code": {"type": ["string", "null"]}, "peak_process_count": {"type": ["integer", "null"], "minimum": 0}, "peak_rss_kib": {"type": ["integer", "null"], "minimum": 0}}},
    "streams": {"type": "object", "additionalProperties": false, "required": ["stdout", "stderr"], "properties": {"stdout": {"$ref": "#/$defs/stream"}, "stderr": {"$ref": "#/$defs/stream"}}},
    "storage": {"type": "object", "additionalProperties": false, "required": ["initial_raw_bytes", "final_raw_bytes", "initial_aggregate_bytes", "final_aggregate_bytes", "minimum_free_bytes", "raw_budget_bytes", "aggregate_budget_bytes", "publication_reserve_bytes"], "properties": {"initial_raw_bytes": {"type": "integer", "minimum": 0}, "final_raw_bytes": {"type": "integer", "minimum": 0}, "initial_aggregate_bytes": {"type": "integer", "minimum": 0}, "final_aggregate_bytes": {"type": "integer", "minimum": 0}, "minimum_free_bytes": {"type": "integer", "minimum": 0}, "raw_budget_bytes": {"type": "integer", "minimum": 0}, "aggregate_budget_bytes": {"type": "integer", "minimum": 0}, "publication_reserve_bytes": {"type": "integer", "minimum": 0}}},
    "machine": {"type": "object", "minProperties": 1}, "identity_files": {"type": "array", "items": {"type": "object"}}
  },
  "$defs": {"stream": {"type": "object", "additionalProperties": false, "required": ["bytes_seen", "sha256", "over_budget"], "properties": {"bytes_seen": {"type": "integer", "minimum": 0}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "over_budget": {"type": "boolean"}}}}
}
