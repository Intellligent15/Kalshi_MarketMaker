{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmm.kalshi.raw_capture.v2",
  "type": "object",
  "required": [
    "schema", "source", "environment", "truth_category", "source_fidelity",
    "market_tickers", "capture_started_at_utc_ns", "requested_duration_seconds",
    "connection_strategy", "websocket_endpoint", "subscription_template",
    "sequence_domain", "credential_environment_variables", "credential_values_persisted",
    "message_counts_by_type", "message_counts_by_market", "connections", "disconnects",
    "connection_segments", "sequence_gaps", "non_monotonic_sequences",
    "capture_continuity", "data_usability", "shutdown"
  ],
  "properties": {
    "schema": {"const": "pmm.kalshi.raw_capture.v2"},
    "source": {"const": "kalshi"},
    "environment": {"const": "production"},
    "truth_category": {"enum": ["Observed", "Synthetic"]},
    "source_fidelity": {"const": "level_2"},
    "market_tickers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "capture_started_at_utc_ns": {"type": "integer", "minimum": 0},
    "capture_ended_at_utc_ns": {"type": "integer", "minimum": 0},
    "requested_duration_seconds": {"type": "integer", "minimum": 1},
    "connection_strategy": {"const": "single_connection_v1"},
    "websocket_endpoint": {"type": "string", "minLength": 1},
    "subscription_template": {"type": "object"},
    "sequence_domain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "topology", "components", "mechanical_validation_key", "limitation"],
      "properties": {
        "status": {"enum": ["documented", "fixture_declared", "unknown"]},
        "topology": {"enum": ["shared", "independent", "unknown"]},
        "components": {"type": "array", "items": {"type": "string"}},
        "mechanical_validation_key": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "limitation": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"topology": {"const": "independent"}}},
          "then": {"properties": {"mechanical_validation_key": {"const": ["connection_segment_id", "venue_subscription_id", "market_ticker"]}}},
          "else": {"properties": {"mechanical_validation_key": {"const": ["connection_segment_id", "venue_subscription_id"]}}}
        },
        {
          "if": {"properties": {"status": {"const": "unknown"}}},
          "then": {"properties": {"topology": {"const": "unknown"}}}
        }
      ]
    },
    "credential_environment_variables": {"type": "array", "items": {"type": "string"}},
    "credential_values_persisted": {"const": false},
    "git_revision": {"type": ["string", "null"]},
    "package_versions": {"type": "object"},
    "message_counts_by_type": {"type": "object"},
    "message_counts_by_market": {"type": "object"},
    "connections": {"type": "integer", "minimum": 0},
    "disconnects": {"type": "integer", "minimum": 0},
    "connection_segments": {"type": "array", "items": {"type": "object"}},
    "sequence_gaps": {"type": "array", "items": {"type": "object"}},
    "non_monotonic_sequences": {"type": "array", "items": {"type": "object"}},
    "raw_record_count": {"type": "integer", "minimum": 0},
    "capture_continuity": {"enum": ["continuous_within_recorded_mechanical_scopes", "observed_discontinuous", "incomplete"]},
    "data_usability": {"enum": ["strict_eligible", "record_only", "unusable"]},
    "shutdown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "clean"],
      "properties": {
        "status": {"enum": ["running", "completed", "interrupted", "failed"]},
        "clean": {"type": "boolean"},
        "error_type": {"type": "string", "minLength": 1}
      }
    }
  },
  "additionalProperties": false
}
