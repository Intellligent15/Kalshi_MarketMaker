{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmm.backtest_result_manifest.v4",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "run_id", "config_sha256", "inputs", "feature_definition_sha256", "scheduling_policy", "execution", "risk", "completeness", "limitations", "non_claims", "products", "aggregate_counts", "artifacts"],
  "properties": {
    "schema": {"const": "pmm.backtest_result_manifest.v4"}, "run_id": {"type": "string", "minLength": 1},
    "config_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "inputs": {"type": "object"},
    "feature_definition_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "scheduling_policy": {"const": "causal_multimarket_v1"},
    "execution": {"type": "object"},
    "risk": {"type": "object", "required": ["engine", "ownership", "traces"], "properties": {"engine": {"const": "cxx_oracle_v2"}, "ownership": {"const": "per_contract_projection"}, "traces": {"type": "array"}}, "additionalProperties": false},
    "completeness": {"const": "complete_observed_interval"}, "limitations": {"type": "array"},
    "non_claims": {"type": "object", "required": ["fees", "accounting", "pnl", "collateral", "margin", "settlement", "portfolio_risk"]},
    "products": {"type": "array", "minItems": 1},
    "aggregate_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "artifacts": {"type": "array", "minItems": 9, "maxItems": 9, "items": {"type": "object", "additionalProperties": false, "required": ["name", "schema", "path", "sha256", "row_count"], "properties": {"name": {"type": "string"}, "schema": {"type": "string"}, "path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "row_count": {"type": "integer", "minimum": 0}}}}
  }
}
