{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmm.product_acquisition_policy.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "payload", "payload_sha256"],
  "properties": {
    "schema": {"const": "pmm.product_acquisition_policy.v1"},
    "payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["venue", "environment", "allowed_hosts", "allowed_redirect_statuses", "maximum_redirects", "stream_chunk_bytes", "maximum_package_bytes", "connect_timeout_seconds", "read_timeout_seconds", "source_deadline_seconds", "package_deadline_seconds", "role_policies"],
      "properties": {
        "venue": {"const": "kalshi"},
        "environment": {"const": "production"},
        "allowed_hosts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "allowed_redirect_statuses": {"const": [301, 302, 303, 307, 308]},
        "maximum_redirects": {"type": "integer", "minimum": 0},
        "stream_chunk_bytes": {"type": "integer", "minimum": 1},
        "maximum_package_bytes": {"type": "integer", "minimum": 1},
        "connect_timeout_seconds": {"type": "integer", "minimum": 1},
        "read_timeout_seconds": {"type": "integer", "minimum": 1},
        "source_deadline_seconds": {"type": "integer", "minimum": 1},
        "package_deadline_seconds": {"type": "integer", "minimum": 1},
        "role_policies": {"type": "object", "minProperties": 1}
      }
    }
  }
}
