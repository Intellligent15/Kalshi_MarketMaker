{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmm.venue_product_terms.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "payload", "payload_sha256"],
  "properties": {
    "schema": {"const": "pmm.venue_product_terms.v1"},
    "payload_sha256": {"$ref": "#/$defs/hash"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "venue", "environment", "revision_label", "effective", "identity", "price",
        "quantity", "payout", "rules", "lifecycle", "settlement", "fees", "source_refs"
      ],
      "properties": {
        "venue": {"const": "kalshi"},
        "environment": {"const": "production"},
        "revision_label": {"type": "string", "minLength": 1},
        "effective": {"$ref": "#/$defs/effective"},
        "identity": {"$ref": "#/$defs/identity"},
        "price": {"$ref": "#/$defs/price"},
        "quantity": {"$ref": "#/$defs/quantity"},
        "payout": {"$ref": "#/$defs/payout"},
        "rules": {"$ref": "#/$defs/rules"},
        "lifecycle": {"$ref": "#/$defs/lifecycle"},
        "settlement": {"$ref": "#/$defs/settlement"},
        "fees": {"$ref": "#/$defs/fees"},
        "source_refs": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utc": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*Z$", "format": "date-time"},
    "decimal": {"type": "string", "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$"},
    "effective": {
      "type": "object", "additionalProperties": false,
      "required": ["from_utc", "until_utc", "basis"],
      "properties": {
        "from_utc": {"$ref": "#/$defs/utc"},
        "until_utc": {"oneOf": [{"$ref": "#/$defs/utc"}, {"type": "null"}]},
        "basis": {"enum": ["venue_explicit", "source_revision_timestamp", "contemporaneous_snapshot", "reviewed_retrospective"]}
      }
    },
    "contract": {
      "type": "object", "additionalProperties": false,
      "required": ["side", "contract_id", "label"],
      "properties": {
        "side": {"enum": ["no", "yes"]},
        "contract_id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1}
      }
    },
    "identity": {
      "type": "object", "additionalProperties": false,
      "required": ["series_ticker", "event_ticker", "market_ticker", "market_type", "title", "yes_sub_title", "no_sub_title", "contracts"],
      "properties": {
        "series_ticker": {"type": "string", "minLength": 1},
        "event_ticker": {"type": "string", "minLength": 1},
        "market_ticker": {"type": "string", "minLength": 1},
        "market_type": {"const": "binary"},
        "title": {"type": "string", "minLength": 1},
        "yes_sub_title": {"type": "string", "minLength": 1},
        "no_sub_title": {"type": "string", "minLength": 1},
        "contracts": {
          "type": "array", "minItems": 2, "maxItems": 2,
          "prefixItems": [
            {"allOf": [{"$ref": "#/$defs/contract"}, {"properties": {"side": {"const": "no"}}}]},
            {"allOf": [{"$ref": "#/$defs/contract"}, {"properties": {"side": {"const": "yes"}}}]}
          ],
          "items": false
        }
      }
    },
    "range": {
      "type": "object", "additionalProperties": false,
      "required": ["start_dollars", "end_dollars", "step_dollars", "start_inclusive", "end_inclusive"],
      "properties": {
        "start_dollars": {"$ref": "#/$defs/decimal"},
        "end_dollars": {"$ref": "#/$defs/decimal"},
        "step_dollars": {"$ref": "#/$defs/decimal"},
        "start_inclusive": {"type": "boolean"},
        "end_inclusive": {"type": "boolean"}
      }
    },
    "price": {
      "type": "object", "additionalProperties": false,
      "required": ["representation", "maximum_decimal_places", "level_structure", "ranges"],
      "properties": {
        "representation": {"const": "fixed_point_dollars"},
        "maximum_decimal_places": {"type": "integer", "minimum": 1},
        "level_structure": {"type": "string", "minLength": 1},
        "ranges": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/range"}}
      }
    },
    "quantity": {
      "type": "object", "additionalProperties": false,
      "required": ["unit", "representation", "maximum_decimal_places", "increment_contracts"],
      "properties": {
        "unit": {"const": "contract"},
        "representation": {"const": "fixed_point_contracts"},
        "maximum_decimal_places": {"type": "integer", "minimum": 1},
        "increment_contracts": {"$ref": "#/$defs/decimal"}
      }
    },
    "payout": {
      "type": "object", "additionalProperties": false,
      "required": ["notional_value_dollars", "ordinary_yes_value_dollars", "ordinary_no_value_dollars", "settlement_value_min_dollars", "settlement_value_max_dollars", "contingent_nonbinary_value_possible"],
      "properties": {
        "notional_value_dollars": {"const": "1.0000"},
        "ordinary_yes_value_dollars": {"const": "1.0000"},
        "ordinary_no_value_dollars": {"const": "1.0000"},
        "settlement_value_min_dollars": {"const": "0.0000"},
        "settlement_value_max_dollars": {"const": "1.0000"},
        "contingent_nonbinary_value_possible": {"type": "boolean"}
      }
    },
    "rules": {
      "type": "object", "additionalProperties": false,
      "required": ["primary", "secondary", "contract_terms_source"],
      "properties": {
        "primary": {"type": "string", "minLength": 1},
        "secondary": {"type": "string", "minLength": 1},
        "contract_terms_source": {"type": "string", "minLength": 1}
      }
    },
    "lifecycle": {
      "type": "object", "additionalProperties": false,
      "required": ["open_time", "close_time", "expected_expiration_time", "latest_expiration_time", "can_close_early", "early_close_condition", "settlement_timer_seconds"],
      "properties": {
        "open_time": {"$ref": "#/$defs/utc"},
        "close_time": {"$ref": "#/$defs/utc"},
        "expected_expiration_time": {"$ref": "#/$defs/utc"},
        "latest_expiration_time": {"$ref": "#/$defs/utc"},
        "can_close_early": {"type": "boolean"},
        "early_close_condition": {"type": ["string", "null"]},
        "settlement_timer_seconds": {"type": "integer", "minimum": 0}
      }
    },
    "settlementSource": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "url"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "url": {"type": "string", "minLength": 1}
      }
    },
    "settlement": {
      "type": "object", "additionalProperties": false,
      "required": ["sources", "rules_source", "implementation_status"],
      "properties": {
        "sources": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/settlementSource"}},
        "rules_source": {"type": "string", "minLength": 1},
        "implementation_status": {"const": "unsupported_not_applied"}
      }
    },
    "fees": {
      "type": "object", "additionalProperties": false,
      "required": ["series_fee_type", "series_fee_multiplier", "maker_fee_status", "waiver_status", "schedule_source", "rounding_source", "implementation_status"],
      "properties": {
        "series_fee_type": {"type": "string", "minLength": 1},
        "series_fee_multiplier": {"$ref": "#/$defs/decimal"},
        "maker_fee_status": {"type": "string", "minLength": 1},
        "waiver_status": {"type": "string", "minLength": 1},
        "schedule_source": {"type": "string", "minLength": 1},
        "rounding_source": {"type": "string", "minLength": 1},
        "implementation_status": {"const": "unsupported_not_applied"}
      }
    }
  }
}
