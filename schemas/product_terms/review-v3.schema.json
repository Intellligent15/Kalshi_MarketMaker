{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmm.product_terms_review.v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "payload", "payload_sha256"],
  "properties": {
    "schema": {"const": "pmm.product_terms_review.v3"},
    "payload_sha256": {"$ref": "#/$defs/hash"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewed_at_utc", "reviewer", "responsibilities", "checklist", "product_terms_sha256", "source_manifest_sha256", "acquisition_policy_sha256", "evidence_profile_sha256", "evidence_map_sha256", "effective_from_utc", "effective_until_utc", "effective_time_basis", "limitations"],
      "properties": {
        "status": {"const": "reviewed"},
        "reviewed_at_utc": {"$ref": "#/$defs/utc"},
        "reviewer": {"type": "object", "additionalProperties": false, "required": ["identity", "identity_kind"], "properties": {"identity": {"type": "string", "minLength": 1}, "identity_kind": {"const": "repository_declared"}}},
        "responsibilities": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "checklist": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["item", "status"], "properties": {"item": {"type": "string", "minLength": 1}, "status": {"const": "accepted"}}}},
        "product_terms_sha256": {"$ref": "#/$defs/hash"},
        "source_manifest_sha256": {"$ref": "#/$defs/hash"},
        "acquisition_policy_sha256": {"$ref": "#/$defs/hash"},
        "evidence_profile_sha256": {"$ref": "#/$defs/hash"},
        "evidence_map_sha256": {"$ref": "#/$defs/hash"},
        "effective_from_utc": {"$ref": "#/$defs/utc"},
        "effective_until_utc": {"$ref": "#/$defs/utc"},
        "effective_time_basis": {"const": "contemporaneous_snapshot"},
        "limitations": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  "$defs": {"hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "utc": {"type": "string", "format": "date-time"}}
}
