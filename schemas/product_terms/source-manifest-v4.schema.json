{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmm.product_terms_source_manifest.v4",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "payload", "payload_sha256"],
  "properties": {
    "schema": {"const": "pmm.product_terms_source_manifest.v4"},
    "payload_sha256": {"$ref": "#/$defs/hash"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["venue", "environment", "acquisition_policy_sha256", "evidence_profile_sha256", "acquisitions", "sources"],
      "properties": {
        "venue": {"const": "kalshi"},
        "environment": {"const": "production"},
        "truth_category": {"enum": ["Observed", "Synthetic"]},
        "acquisition_policy_sha256": {"$ref": "#/$defs/hash"},
        "evidence_profile_sha256": {"$ref": "#/$defs/hash"},
        "acquisitions": {"type": "array", "minItems": 1, "maxItems": 2, "items": {"$ref": "#/$defs/acquisition"}},
        "sources": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source"}}
      },
      "allOf": [{
        "if": {"required": ["truth_category"], "properties": {"truth_category": {"const": "Synthetic"}}},
        "then": {"properties": {"sources": {"items": {"properties": {
          "requested_url": {"pattern": "^https://synthetic\\.invalid(?::443)?(?:/|$)"},
          "final_url": {"pattern": "^https://synthetic\\.invalid(?::443)?(?:/|$)"}
        }}}}}
      }]
    }
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utc": {"type": "string", "format": "date-time"},
    "acquisition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observation_id", "started_at_utc", "completed_at_utc", "tool_name", "tool_version"],
      "properties": {
        "observation_id": {"enum": ["opening", "closing"]},
        "started_at_utc": {"$ref": "#/$defs/utc"},
        "completed_at_utc": {"$ref": "#/$defs/utc"},
        "tool_name": {"const": "pmm_product_terms"},
        "tool_version": {"const": "product-acquisition.v4"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source_key", "observation_id", "role", "requested_url", "final_url", "redirect_history", "http_status", "media_type", "retrieval_started_at_utc", "retrieval_completed_at_utc", "elapsed_milliseconds", "path", "byte_length", "sha256", "tool_name", "tool_version", "response_headers"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "source_key": {"type": "string", "minLength": 1},
        "observation_id": {"enum": ["opening", "closing"]},
        "role": {"enum": ["event_metadata_record", "market_record", "series_record_and_contract_document_identity", "official_fee_rounding_document", "official_fixed_point_document", "official_settlement_document", "official_contract_terms_document", "official_certification_document"]},
        "requested_url": {"type": "string", "format": "uri"},
        "final_url": {"type": "string", "format": "uri"},
        "redirect_history": {"type": "array", "maxItems": 5},
        "http_status": {"type": "integer", "minimum": 200, "maximum": 299},
        "media_type": {"enum": ["application/json", "application/pdf", "text/markdown", "text/plain"]},
        "retrieval_started_at_utc": {"$ref": "#/$defs/utc"},
        "retrieval_completed_at_utc": {"$ref": "#/$defs/utc"},
        "elapsed_milliseconds": {"type": "integer", "minimum": 0},
        "path": {"type": "string", "minLength": 1},
        "byte_length": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/hash"},
        "tool_name": {"const": "pmm_product_terms"},
        "tool_version": {"const": "product-acquisition.v4"},
        "response_headers": {"type": "object"},
        "venue_updated_at": {"$ref": "#/$defs/utc"}
      }
    }
  }
}
