{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmm.product_catalog.v1",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "payload", "payload_sha256"],
  "properties": {
    "schema": {"const": "pmm.product_catalog.v1"},
    "payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "payload": {
      "type": "object", "additionalProperties": false, "required": ["entries"],
      "properties": {"entries": {"type": "array", "minItems": 1, "items": {
        "type": "object", "additionalProperties": false,
        "required": ["venue", "environment", "series_ticker", "event_ticker", "market_ticker", "effective_from_utc", "effective_until_utc", "package", "product_terms_sha256", "source_manifest_sha256", "review_sha256"],
        "properties": {
          "venue": {"const": "kalshi"}, "environment": {"const": "production"},
          "series_ticker": {"type": "string", "minLength": 1},
          "event_ticker": {"type": "string", "minLength": 1},
          "market_ticker": {"type": "string", "minLength": 1},
          "effective_from_utc": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*Z$", "format": "date-time"},
          "effective_until_utc": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*Z$", "format": "date-time"},
          "package": {"type": "string", "minLength": 1},
          "product_terms_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "source_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "review_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }}}
    }
  }
}
